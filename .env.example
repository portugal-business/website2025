# ── Business Portugal — variables d'environnement ──────────────────────────
# Copier en `.env.local` et renseigner. Ne jamais committer `.env.local`.

# Domaine canonique du site (sans slash final). Domaine validé : portugal-business.com.
NEXT_PUBLIC_SITE_URL="https://portugal-business.com"

# Email de contact public (mentions légales, JSON-LD, désinscription).
NEXT_PUBLIC_CONTACT_EMAIL="contact@portugal-business.com"

# Mesure d'audience Plausible (sans cookie). Domaine nu (sans https://).
# Laisser vide pour désactiver le script.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# ── Formulaire de contact → notification email (Brevo) ─────────────────────
# Sans BREVO_API_KEY : en DEV le formulaire simule un succès ; en PROD il
# renvoie une erreur (pas de faux succès). Vérifier SPF/DKIM du domaine d'envoi.
BREVO_API_KEY=""
BREVO_TO_EMAIL="audrey.marques@portugal-business.com"

# ── Persistance des leads (Supabase, via API REST — pas de SDK) ────────────
# Optionnel mais recommandé : ne perd pas un lead si l'email échoue.
# Nécessite la table `leads` (voir SQL ci-dessous) avec RLS.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ── SQL de la table `leads` (à exécuter dans Supabase) ─────────────────────
# create table public.leads (
#   id uuid primary key default gen_random_uuid(),
#   created_at timestamptz not null default now(),
#   first_name text not null,
#   last_name  text not null,
#   email      text not null,
#   project_type text not null,
#   country    text not null,
#   timeframe  text not null,
#   message    text not null,
#   source     text not null default 'contact-form'
# );
# alter table public.leads enable row level security;
# -- Aucune policy publique : insert/select uniquement via service_role (serveur).
